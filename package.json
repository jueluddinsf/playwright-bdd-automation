{
  "name": "codeless-playwright-bdd-framework",
  "version": "1.0.0",
  "description": "Enterprise codeless Playwright + Cucumber BDD framework powered by reusable Gherkin steps",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:local": "cross-env TEST_ENV=local cucumber-js",
    "test:sat": "cross-env TEST_ENV=sat cucumber-js",
    "test:stage": "cross-env TEST_ENV=stage cucumber-js",
    "test:prod": "cross-env TEST_ENV=prod cucumber-js",
    "test:ui": "cucumber-js features/tests/ui/**/*.feature features/examples/ui/**/*.feature",
    "test:api": "cucumber-js features/tests/api/**/*.feature features/examples/api/**/*.feature",
    "test:e2e": "cucumber-js features/tests/e2e/**/*.feature",
    "test:performance": "cucumber-js features/examples/performance/**/*.feature",
    "test:tag": "cross-env cucumber-js --tags ${TAG:-@smoke}",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "test:headed": "cross-env HEADLESS=false cucumber-js",
    "test:headless": "cross-env HEADLESS=true cucumber-js",
    "test:edge": "cross-env BROWSER_CHANNEL=msedge cucumber-js",
    "test:chrome": "cross-env BROWSER_CHANNEL=chrome cucumber-js",
    "test:dry": "cucumber-js --dry-run",
    "lint": "eslint page-objects step-definitions setup",
    "format": "prettier --write \"**/*.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "*",
    "@cucumber/pretty-formatter": "*",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "*",
    "cross-env": "*",
    "eslint": "*",
    "eslint-plugin-playwright": "*",
    "lighthouse": "^13.0.3",
    "playwright": "*",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "*"
  },
  "dependencies": {
    "playwright-bdd-steps": "file:lib/playwright-bdd-steps-1.0.3.tgz"
  }
}
