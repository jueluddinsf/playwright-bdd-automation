{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: Current Feature File",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/cucumber-js",
            "args": [
                "${file}",
                "--tags",
                "not @ignore"
            ],
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Debug: Run @smoke Tag",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/cucumber-js",
            "args": [
                "features/**/*.feature",
                "--tags",
                "@smoke"
            ],
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}